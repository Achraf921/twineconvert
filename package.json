{
  "name": "client-conversion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "tsx scripts/generate-registry-meta.ts && npm run copy-ffmpeg-core",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "npm run copy-ffmpeg-core && vitest run --config vitest.browser.config.ts",
    "copy-ffmpeg-core": "mkdir -p public/ffmpeg public/ifc && cp node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.js public/ffmpeg/ && cp node_modules/@ffmpeg/core/dist/umd/ffmpeg-core.wasm public/ffmpeg/ && cp node_modules/web-ifc/web-ifc.wasm public/ifc/ && cp node_modules/web-ifc/web-ifc-mt.wasm public/ifc/",
    "submit:google": "node scripts/submit-urls-to-google.mjs",
    "submit:indexnow": "node scripts/submit-urls-to-indexnow.mjs"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@imgly/background-removal": "^1.7.0",
    "@jsquash/avif": "^2.1.1",
    "@types/dompurify": "^3.0.5",
    "@types/three": "^0.184.1",
    "chess.js": "^1.4.0",
    "docx": "^9.6.1",
    "dompurify": "^3.4.2",
    "epubjs": "^0.3.93",
    "geist": "^1.7.0",
    "gifenc": "^1.0.3",
    "heic2any": "^0.0.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "midi-file": "^1.2.4",
    "next": "16.2.6",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "postal-mime": "^2.7.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sax": "^1.6.0",
    "tesseract.js": "^7.0.0",
    "three": "^0.184.0",
    "twitter-archive-reader": "^7.3.3",
    "utif": "^3.1.0",
    "web-ifc": "^0.0.77",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sax": "^1.2.7",
    "@types/utif": "^3.0.6",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "googleapis": "^171.4.0",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
